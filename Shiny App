library(shiny)
library(dplyr)
library(unmarked)
library(HDInterval)

#function I created that processes the data into the correct format for gdistsamp
source("Data_processing_function.R")
#predicts abundance and CIs based on entered data for a pre-determinded gdistsamp model
source("estimate_function.R")


#pull my chosen model from a file I've created
CHOSEN_MODEL_PATH <- "chosen_model.rds"

load_chosen_model <- function() {
  if (file.exists(CHOSEN_MODEL_PATH)) {
    readRDS(CHOSEN_MODEL_PATH)
  } else {
    NULL
  }
}

#make sure the uploaded data is in the right format
required_transect_cols  <- c("ec5_uuid", "X3_Woodland_name", "X4_Date")
required_sightings_cols <- c("ec5_parent_uuid", "X18_Perpendicular_dis", "X19_TreeGround",
                             "X17_Squirrel_species", "X16_Transect_section")
required_tlengths_cols  <- c("Site", "length")

#give error message if the files don't have the required columns as o/w my code fails silently
check_columns <- function(df, required, file_label) {
  missing <- setdiff(required, names(df))
  if (length(missing) > 0) {
    #output the names of missing columns for clarity
    stop(paste0(file_label, " is missing expected column(s): ", paste(missing, collapse = ", ")))
  }
}

ui <- fluidPage(
  titlePanel("Squirrel Abundance Predictor"),
  sidebarLayout(
    sidebarPanel(
      h4("1. Upload data"),
      fileInput("transect_file", "Transect data (.csv)", accept = ".csv"),
      fileInput("sightings_file", "Sightings data (.csv)", accept = ".csv"),
      fileInput("tlengths_file", "Transect lengths (.xlsx)", accept = c(".xlsx", ".xls")),
      selectInput("species", "Species", choices = c("Red", "Grey")),
      #Using 2010-current year as the input options
      selectInput("year", "Year", choices = rev(2010:as.numeric(format(Sys.Date(), "%Y")))),
      selectInput("season", "Season", choices = c("Spring", "Autumn")),
      actionButton("process_btn", "Process data", class = "btn-primary"),
      
      #can override my chosen model
      h4("2. Model"),
      fileInput("model_file", "Fitted model (.rds) - optional, overrides the current model",
                accept = ".rds"),
      h4("3. Estimate"),
      numericInput("area_conifer", "Coniferous Area (km²)", value = 165.8453),
      numericInput("area_all", "Total Area (km²)", value = 177.1593),
      numericInput("nsim", "Bootstrap simulations", value = 1000, min = 100, step = 100),
      numericInput("ncores", "Cores for bootstrap", value = 4, min = 1),
      actionButton("estimate_btn", "Predict abundance", class = "btn-success")
      
    ),
    mainPanel(
      tabsetPanel(
        tabPanel("Data preview", DT::DTOutput("data_preview")),
        tabPanel("Abundance estimate", tableOutput("estimate_out")),
        tabPanel("Diagnostic plots",
                 h4("Detection function"),
                 plotOutput("detection_plot", height = "350px"),
                 h4("Bootstrap distribution (All woodland)"),
                 plotOutput("bootstrap_hist", height = "350px"))
      )
    )
  )
)

server <- function(input, output, session) {
  #I want the inputs to be entered step by step rather than reactively as the
  #Bootstrapping can take a while
  rv <- reactiveValues(joined_df = NULL, estimate = NULL, pb = NULL, sq_mod = NULL)
  
  observeEvent(input$process_btn, {
    #make sure all expected files are added
    req(input$transect_file, input$sightings_file, input$tlengths_file)
    
    transect_data <- read.csv(input$transect_file$datapath, header = TRUE)
    sightings     <- read.csv(input$sightings_file$datapath, header = TRUE)
    tlengths      <- readxl::read_xlsx(input$tlengths_file$datapath)
    
    joined <- tryCatch({
      check_columns(transect_data, required_transect_cols, "Transect data file")
      check_columns(sightings, required_sightings_cols, "Sightings file")
      check_columns(tlengths, required_tlengths_cols, "Transect lengths file")
      combine_data(transect_data, sightings, tlengths,
                   species_filter = input$species,
                   Year_filter    = as.numeric(input$year),
                   Season_filter  = input$season)
    },
      error = function(e) {
        #visible error message in case combine_data() errors
        showNotification(paste("Error processing data:", e$message), type = "error")
        NULL
      }
    )
    
    rv$joined_df <- joined
  })
  
  output$data_preview <- DT::renderDT({
    #make sure joined_df is available
    req(rv$joined_df)
    #output joined_df
    DT::datatable(rv$joined_df)
  })
  
  #make the app display reactive to the entry of new data
  newdata_reactive <- reactive({
    req(rv$joined_df)
    cols <- intersect(c("Transect", "Year", "Season"), names(rv$joined_df))
    rv$joined_df %>%
      select(all_of(cols)) %>%
      distinct()
  })
  
 
  observeEvent(input$estimate_btn, {
    req(rv$joined_df)
    #check if a model has been uploaded
    sq_mod <- if (!is.null(input$model_file)) {
      tryCatch(readRDS(input$model_file$datapath), error = function(e) NULL)
    } else {
      #if not use my model
        load_chosen_model()
    }
    #if no model is still available ask for name of file to be uploaded
    if (is.null(sq_mod)) {
      showNotification("No model available - upload one or add chosen_model.rds.",
                       type = "error")
      return(invisible(NULL))
    }
    
    newdata <- newdata_reactive()
    
    #show progress bar for bootstrapping
    withProgress(message = "Running multiple prediction simulations...", value = 0.1, {
      result <- tryCatch(
        estimate_population(
          sq_mod = sq_mod, newdata = newdata,
          area_conifer = input$area_conifer, area_all = input$area_all,
          nsim = input$nsim, ncores = input$ncores
        ),
        #error message incase bootstrap fails
        error = function(e) {
          showNotification(paste("Error estimating abundance:", e$message), type = "error")
          NULL
        }
      )
      
      if (is.null(result)) {
        rv$estimate <- NULL; rv$pb <- NULL; rv$sq_mod <- NULL
      } else {
        rv$estimate <- result$estimate
        rv$pb <- result$pb
        rv$sq_mod <- sq_mod
      }
      #moves the progress bar forward
      incProgress(0.9)
    })
  })
  
  output$estimate_out <- renderTable({
    req(rv$estimate)
    #dataframe displays better than the matrix
    df <- as.data.frame(rv$estimate)
    cbind(Area = rownames(df), df, row.names = NULL)
  })
  
  #create plot of the detection function
  output$detection_plot <- renderPlot({
    req(rv$sq_mod)
    sig <- exp(coef(rv$sq_mod, type = "det"))
    plot(function(x) gxexp(x, rate = sig), 0, 50,
         xlab = "Distance (m)", ylab = "Detection probability",
         las = 1, lwd = 2, col = "brown")
  })
  
  #bootstrap simulations of the abundance
  output$bootstrap_hist <- renderPlot({
    req(rv$pb)
    hist(rv$pb@t.star[, 2],
         xlab = "Bootstrapped abundance (All woodland)",
         main = "Bootstrap distribution")
  })
}
shinyApp(ui, server)
  
